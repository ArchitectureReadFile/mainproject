# ───────────────────────────────────────────
# Database
# ───────────────────────────────────────────
DATABASE_URL=mysql+pymysql://유저명:비밀번호@localhost:3306/DB명
MARIADB_ROOT_PASSWORD=change_me_root_password
MARIADB_DATABASE=readfile
MARIADB_USER=user
MARIADB_PASSWORD=change_me_app_password
SQLALCHEMY_ECHO=false

# ───────────────────────────────────────────
# JWT
# ───────────────────────────────────────────
# 키 생성: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your_secret_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ───────────────────────────────────────────
# CORS
# ───────────────────────────────────────────
CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# ───────────────────────────────────────────
# Redis
# Docker 사용 시: REDIS_HOST=redis (docker-compose 서비스명)
# 로컬 직접 실행 시: REDIS_HOST=localhost
# ───────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ───────────────────────────────────────────
# 로그인 시도 제한
# ───────────────────────────────────────────
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
LOGIN_RATE_LIMIT_BLOCK_SECONDS=300

# ───────────────────────────────────────────
# Ollama AI 설정
# Docker 내부 사용 시: OLLAMA_HOST=http://ollama:11434 (docker-compose에서 주입됨)
# 외부 서버 사용 시: OLLAMA_HOST=http://<IP>:11434
# ngrok 터널 사용 시: OLLAMA_HOST=https://xxxx.ngrok.io
# ───────────────────────────────────────────
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b               # 사용할 모델 (예: qwen2.5:1.5b, qwen2.5:7b)
OLLAMA_NUM_CTX=8192                   # 컨텍스트 윈도우 크기
OLLAMA_NUM_PREDICT=3072               # 최대 생성 토큰 수
OLLAMA_TIMEOUT_SECONDS=600            # 요약 타임아웃 (초)
OLLAMA_HTTP_POOL_CONNECTIONS=10       # HTTP connection pool 수
OLLAMA_HTTP_POOL_MAXSIZE=20           # 최대 동시 연결 재사용 수

# ───────────────────────────────────────────
# 요약 파이프라인
# ───────────────────────────────────────────
SUMMARY_MAX_TEXT_CHARS=15000          # Reduce 단계 입력 최대 글자 수
SUMMARY_MAP_INPUT_CHARS=5500          # Map 단계 청크당 최대 글자 수
SUMMARY_CHUNK_PAGES=2                 # 페이지 단위 청크 크기 (폴백 시 사용)

# ───────────────────────────────────────────
# 그룹 문서 RAG chunking 전략
# DOCUMENT_CHUNK_STRATEGY
#   auto    : sections → real pages → text fallback 순서로 자동 선택
#   section : ODL 구조 기반 섹션 청킹 강제 (sections 없으면 text로 downgrade)
#   page    : 실제 page 정보 기반 청킹 강제 (estimated page만 있으면 text로 downgrade)
#   text    : body_text 문단/길이 기반 청킹 강제
# DOCUMENT_CHUNK_TARGET_CHARS
#   body chunk의 소프트 목표 길이
# DOCUMENT_CHUNK_MAX_CHARS
#   body chunk의 절대 상한 길이 (초과 시 강제 분할)
# ───────────────────────────────────────────
DOCUMENT_CHUNK_STRATEGY=auto
DOCUMENT_CHUNK_TARGET_CHARS=1000
DOCUMENT_CHUNK_MAX_CHARS=1500

# ───────────────────────────────────────────
# Qdrant 벡터 DB 설정
# Docker 사용 시: QDRANT_HOST=qdrant (docker-compose에서 주입됨)
# 로컬 직접 실행 시: QDRANT_HOST=localhost
# ───────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=rag_chunks

# ───────────────────────────────────────────
# 임베딩 모델 설정
# EMBEDDING_PREFIX: e5 (E5 계열) | none (KURE-v1, ko-sroberta 등 비-E5 계열)
# ───────────────────────────────────────────
EMBEDDING_MODEL=intfloat/multilingual-e5-base   # HuggingFace 모델명
EMBEDDING_CACHE_DIR=/app/runtime/cache          # 모델 캐시 디렉토리
EMBEDDING_PREFIX=e5                             # e5 | none
EMBEDDING_DIM=768                               # 모델 출력 차원 (E5-base: 768)

# ───────────────────────────────────────────
# 런타임 산출물 경로
# Docker 기준 /app/runtime/*, 로컬 기준 backend/runtime/* 로 맞춘다.
# ───────────────────────────────────────────
UPLOAD_DIR=/app/runtime/uploads/documents
EXPORT_BASE_DIR=/app/runtime/exports

# ───────────────────────────────────────────
# 인증 쿠키 정책
# 로컬 개발: SECURE=false, SAMESITE=lax
# 운영(HTTPS): SECURE=true, SAMESITE=lax
#
# AUTH_COOKIE_SECURE
#   로컬: false (HTTP에서 쿠키 전송 허용)
#   운영: true  (HTTPS 전용, 필수 보안 설정)
# AUTH_COOKIE_SAMESITE
#   lax    : 대부분의 환경에서 권장 (CSRF 방어 + 일반 탐색 허용)
#   strict : 외부 링크 경유 시 쿠키 전송 차단 (더 엄격)
# AUTH_COOKIE_PATH
#   쿠키 유효 경로. 기본값 / 유지 권장
# AUTH_ACCESS_COOKIE_HTTPONLY
#   true  : 권장. 프론트가 JS로 access_token을 직접 읽지 않으므로 HttpOnly 가능
#   false : JS에서 쿠키를 직접 읽어야 하는 경우에만 사용
# AUTH_REFRESH_COOKIE_HTTPONLY
#   true  : 항상 true 유지 권장
# ───────────────────────────────────────────
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_PATH=/
AUTH_ACCESS_COOKIE_HTTPONLY=true
AUTH_REFRESH_COOKIE_HTTPONLY=true

# ───────────────────────────────────────────
# ODL hybrid OCR 설정
# scanned/image PDF 대응을 위해 opendataloader-pdf hybrid backend를 사용한다.
# backend/worker는 아래 URL로 hybrid backend에 접속한다.
# ───────────────────────────────────────────
ODL_OUTPUT_FORMAT=markdown,json
ODL_IMAGE_OUTPUT=off
ODL_HYBRID=docling-fast
ODL_HYBRID_URL=http://odl_hybrid:5002
ODL_HYBRID_TIMEOUT=180000             # milliseconds (OpenDataLoader 공식 문서 기준. 기본값 30000, 운영 권장 180000 이상)
ODL_HYBRID_FALLBACK=false

# ───────────────────────────────────────────
# 이메일 (회원가입 인증 코드 발송)
# Gmail 사용 시 앱 비밀번호 필요:
# https://myaccount.google.com/apppasswords
# ───────────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# ───────────────────────────────────────────
# OAuth 2.0 (Google, GitHub) 소셜 로그인
# ───────────────────────────────────────────
# [Google OAuth 설정]
# https://console.cloud.google.com/auth/clients?hl=ko 에서 앱 생성 후 환경변수에 기입
# (Google은 하나의 앱에서 여러 리다이렉션 URI를 지원하므로, 로컬용과 배포용을 하나의 앱에서 설정 가능)
# - 개발환경 Callback URL: http://localhost:8000/api/auth/social/google/callback
# - 배포환경 Callback URL: https://jiyun.dev/api/auth/social/google/callback
# -----------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# [GitHub OAuth 설정]
# https://github.com/settings/apps/new 에서 앱 생성 후 환경변수에 기입
# (GitHub은 앱당 하나의 리다이렉션 URI만 지원하므로, 로컬 개발용과 배포용 각각 별도의 앱 생성 필요)
#
# (1) 로컬 개발용 App 설정:
# - Homepage URL: http://localhost:5173
# - Callback URL: http://localhost:8000/api/auth/social/github/callback
#
# (2) 배포환경(프로덕션)용 App 설정:
# - Homepage URL: https://jiyun.dev
# - Callback URL: https://jiyun.dev/api/auth/social/github/callback
# -----------------------------------------------------------
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here


# ───────────────────────────────────────────
# 프론트엔드 & 백엔드 URL 설정( OAuth 리다이렉션 시 사용)
#
# (1) 개발환경: http://localhost:5173 (프론트엔드), http://localhost:8000 (백엔드)
#
# (2) 배포환경: https://jiyun.dev (프론트엔드, 백엔드)
# ───────────────────────────────────────────
FRONTEND_URL=your_frontend_url_here
BACKEND_URL=your_backend_url_here
