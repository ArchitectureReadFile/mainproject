# ───────────────────────────────────────────
# Database
# ───────────────────────────────────────────
DATABASE_URL=mysql+pymysql://유저명:비밀번호@localhost:3306/DB명

# ───────────────────────────────────────────
# JWT
# ───────────────────────────────────────────
# 키 생성: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your_secret_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ───────────────────────────────────────────
# CORS
# ───────────────────────────────────────────
CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# ───────────────────────────────────────────
# Redis
# Docker 사용 시: REDIS_HOST=redis (docker-compose 서비스명)
# 로컬 직접 실행 시: REDIS_HOST=localhost
# ───────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ───────────────────────────────────────────
# 로그인 시도 제한
# ───────────────────────────────────────────
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
LOGIN_RATE_LIMIT_BLOCK_SECONDS=300

# ───────────────────────────────────────────
# Ollama AI 설정
# Docker 내부 사용 시: OLLAMA_HOST=http://ollama:11434 (docker-compose에서 주입됨)
# 외부 서버 사용 시: OLLAMA_HOST=http://<IP>:11434
# ngrok 터널 사용 시: OLLAMA_HOST=https://xxxx.ngrok.io
# ───────────────────────────────────────────
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b               # 사용할 모델 (예: qwen2.5:1.5b, qwen2.5:7b)
OLLAMA_NUM_CTX=8192                   # 컨텍스트 윈도우 크기
OLLAMA_NUM_PREDICT=3072               # 최대 생성 토큰 수
OLLAMA_TIMEOUT_SECONDS=600            # 요약 타임아웃 (초)

# ───────────────────────────────────────────
# 요약 파이프라인
# ───────────────────────────────────────────
SUMMARY_MAX_TEXT_CHARS=15000          # Reduce 단계 입력 최대 글자 수
SUMMARY_MAP_INPUT_CHARS=5500          # Map 단계 청크당 최대 글자 수
SUMMARY_CHUNK_PAGES=2                 # 페이지 단위 청크 크기 (폴백 시 사용)

# ───────────────────────────────────────────
# Qdrant 벡터 DB 설정
# Docker 사용 시: QDRANT_HOST=qdrant (docker-compose에서 주입됨)
# 로컬 직접 실행 시: QDRANT_HOST=localhost
# ───────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=precedents

# ───────────────────────────────────────────
# 임베딩 모델 설정
# EMBEDDING_PREFIX: e5 (E5 계열) | none (KURE-v1, ko-sroberta 등 비-E5 계열)
# ───────────────────────────────────────────
EMBEDDING_MODEL=intfloat/multilingual-e5-base   # HuggingFace 모델명
EMBEDDING_CACHE_DIR=/app/.model_cache           # 모델 캐시 디렉토리
EMBEDDING_PREFIX=e5                             # e5 | none
EMBEDDING_DIM=768                               # 모델 출력 차원 (E5-base: 768)

# ───────────────────────────────────────────
# 이메일 (회원가입 인증 코드 발송)
# Gmail 사용 시 앱 비밀번호 필요:
# https://myaccount.google.com/apppasswords
# ───────────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
